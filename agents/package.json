{
  "name": "detection-agents",
  "version": "3.0.0",
  "description": "LangGraph-based autonomous detection engineering agents",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "orchestrate": "tsx src/cli.ts orchestrate",
    "analyze": "tsx src/cli.ts analyze",
    "validate": "tsx src/cli.ts validate",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.12",
    "@langchain/core": "^1.1.17",
    "@langchain/langgraph": "^1.1.2",
    "@types/js-yaml": "^4.0.9",
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "js-yaml": "^4.1.1",
    "uuid": "^10.0.0",
    "yaml": "^2.4.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
