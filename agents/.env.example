# ───────────────────────────────────────────────
# Detection Pipeline – Environment Configuration
# ───────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# See docs/E2E-TESTING-GUIDE.md for detailed setup instructions.

# ── SIEM Platform ────────────────────────────────
# REQUIRED: Which SIEM the pipeline generates detections for.
# This controls the output format, validation method, and query language.
#
#   splunk   → SPL YAML (security_content format), validated with contentctl
#   sentinel → KQL analytics rules, validated with Azure CLI
#   elastic  → EQL/TOML detection rules, validated with Elastic detection-rules CLI
#   sigma    → Platform-agnostic Sigma YAML, validated with pySigma
#
SIEM_PLATFORM=splunk

# ── LLM ─────────────────────────────────────────
# REQUIRED: At least one LLM API key.
# See docs/MODELS.md for full provider setup (OpenAI, Azure, Google).
ANTHROPIC_API_KEY=

# Model to use (default: claude-sonnet-4-20250514)
# For OpenAI: gpt-4o  |  For Google: gemini-2.0-flash
# LLM_MODEL=claude-sonnet-4-20250514

# ── Repository Paths ────────────────────────────
# REQUIRED: Where your detection content repository is cloned.
# For Splunk: path to splunk/security_content
# For Elastic: path to elastic/detection-rules
# For Sigma: path to your sigma rule collection
# For Sentinel: path to your KQL rule collection
# SECURITY_CONTENT_PATH=./security_content

# Where attack_data is cloned (Splunk-specific, optional)
# Only needed if SIEM_PLATFORM=splunk and you want to export attack data
# ATTACK_DATA_PATH=./attack_data

# ── Attack Range (Splunk only) ──────────────────
# These settings are ONLY needed if SIEM_PLATFORM=splunk and you use Attack Range.
# If you use a different lab (Docker, Azure VMs, manual VMs), skip this section.

# Where attack_range is cloned
# ATTACK_RANGE_PATH=./attack_range

# Path to the Poetry virtualenv activate script
# ATTACK_RANGE_VENV=

# Default Windows target name (e.g. ar-win-mylab-0)
# ATTACK_RANGE_DEFAULT_TARGET=

# Engine: ART (Atomic Red Team) or PurpleSharp
# ATTACK_RANGE_ENGINE=ART

# Ansible playbook for custom atomics
# ATTACK_RANGE_CUSTOM_PLAYBOOK=deploy_custom_atomics.yml

# ── Sentinel / Azure (sentinel only) ────────────
# These settings are ONLY needed if SIEM_PLATFORM=sentinel.

# Azure subscription and workspace for KQL validation
# AZURE_SUBSCRIPTION_ID=
# AZURE_RESOURCE_GROUP=
# AZURE_WORKSPACE_NAME=

# ── Elastic (elastic only) ──────────────────────
# These settings are ONLY needed if SIEM_PLATFORM=elastic.

# Elasticsearch endpoint for validation queries
# ELASTICSEARCH_URL=http://localhost:9200
# KIBANA_URL=http://localhost:5601

# ── Sigma (sigma only) ──────────────────────────
# These settings are ONLY needed if SIEM_PLATFORM=sigma.

# Which backend to convert Sigma rules to for validation
# Options: splunk, microsoft365defender, elasticsearch
# SIGMA_TARGET_BACKEND=splunk

# ── Splunk MCP ──────────────────────────────────
# Set to "true" to enable live Splunk MCP calls (Splunk only).
# When SIEM_PLATFORM is not splunk, this is ignored.
# SPLUNK_MCP_ENABLED=false

# MCP transport (default: stdio)
# MCP_SERVER_URL=stdio

# ── Pipeline Behaviour ──────────────────────────
# Set to "true" to skip all external calls (useful for testing).
# Recommended for your first run to see the pipeline flow without needing a lab.
# DRY_RUN=false

# Max detections to create in one pipeline run
# MAX_DETECTIONS_PER_RUN=3

# Seconds to wait for SIEM log ingestion after atomics
# INGESTION_WAIT_SECONDS=120

# ── Validation Tool Override ─────────────────────
# Override the default validation command for your SIEM.
# Defaults: splunk→contentctl, sentinel→az CLI, elastic→detection-rules, sigma→pySigma
# VALIDATION_TOOL=
